# Cloudflare Pages headers. Files in /public are copied into the static export,
# so this ships as out/_headers. https://developers.cloudflare.com/pages/configuration/headers/

# Security headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Next.js fingerprints these assets, so they can be cached forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
